__pycache__/
*.py[cod]
.venv/
venv/

# Brain DB is a local artifact rebuilt from data_store/knowledge.jsonl on
# every bootstrap; only the JSONL is committed and tracked across collaborators.
data_store/*.db
data_store/*.db-journal
data_store/*.db-wal
data_store/*.db-shm

# Claude Code per-user/machine state (MCP approvals, local permissions)
.claude/settings.local.json

.vscode/
.idea/
.DS_Store

# Brain-capture skill draft buffer (per-session, not committed)
.brain-drafts/

# Agent-OS v1.0.0 per-machine state. The .agent-os/project.yaml.template is
# committed (placeholders are rendered per-machine by bootstrap-ccp); the
# rendered manifest, runtime/task state, and fetched governance files are
# not.
.agent-os/project.yaml
.agent-os/runtime/
.agent-os/tasks/
.agent-os/schemas/
.agent-os/contracts/
.agent-os.lock
AGENT_OS_CONSTITUTION.md

# Generated per-machine by scripts/bootstrap.* — has absolute paths
.mcp.json
